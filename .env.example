# Environment: development, testing, production
ENVIRONMENT=development

# Logging
LOG_LEVEL=DEBUG

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard settings
DASHBOARD_PORT=8501

# API URL (used by dashboard to call the API)
# Must match API_PORT if changed
API_URL=http://localhost:8000

# MLflow (optional, for tracking)
MLFLOW_TRACKING_URI=./mlruns
